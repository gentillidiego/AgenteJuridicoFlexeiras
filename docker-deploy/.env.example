# ==========================================
# OpenGravity — Variáveis de Ambiente
# Copie este arquivo para .env e preencha
# ==========================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=SUBSTITUA_PELO_SEU_TOKEN
TELEGRAM_ALLOWED_USER_IDS=SEU_ID_TELEGRAM

# --- LLM Principal (Groq) ---
GROQ_API_KEY=SUBSTITUA_PELA_SUA_CHAVE_GROQ

# --- LLM Fallback (OpenRouter) ---
OPENROUTER_API_KEY=SUBSTITUA_PELA_SUA_CHAVE
OPENROUTER_MODEL=openrouter/free

# --- Banco de dados ---
DB_PATH=./memory.db

# --- Google (gerenciado pelo gog CLI) ---
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
GOG_ACCOUNT=SEU@gmail.com

# --- WhatsApp ---
WHATSAPP_ENABLED=true
# Deixe vazio para Modo Público (aceita qualquer número)
# Para restringir: separe por vírgula sem espaços — ex: 5511999999999,5521888888888
WHATSAPP_ALLOWED_NUMBERS=

# --- ElevenLabs TTS (voz) ---
ELEVENLABS_API_KEY=SUBSTITUA_PELA_SUA_CHAVE
ELEVENLABS_VOICE_ID=cgSgspJ2msm6clMCkdW9

# --- Ambiente ---
NODE_ENV=production
